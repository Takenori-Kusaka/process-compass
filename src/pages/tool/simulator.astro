---
// プロセス提案シミュレーター(M7 プロトタイプ #61)
// ビルド時に知識ベース(src/data/tailoring/)と参照モデルを JSON として埋め込み、
// クライアント側でルールエンジン(src/lib/tailoring-engine.mjs)を実行する。
// 入力はブラウザの外へ送信しない(要件定義の非機能要件)
import { getCollection } from 'astro:content';
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';

const base = import.meta.env.BASE_URL;
const b = base.endsWith('/') ? base : `${base}/`;

const [questionsEntry] = await getCollection('tailoringQuestions');
const ruleFiles = await getCollection('tailoringRules');
const [practicesEntry] = await getCollection('tailoringPractices');
const [constraintsEntry] = await getCollection('tailoringConstraints');
const processes = await getCollection('processes');
const integrated = processes.find((p) => p.id === 'integrated');
if (!integrated) throw new Error('integrated.yaml が見つかりません');

// 規則はファイル名順で平坦化する(同順位の適用順をデータの記載順で決定的にする)
const rules = ruleFiles
  .sort((a, z) => a.id.localeCompare(z.id))
  .flatMap((f) => f.data.rules);

// 表示用ラベル(id → 名前)
const labels: Record<string, string> = {};
for (const g of integrated.data.gates) labels[`gate:${g.id}`] = g.name;
for (const r of integrated.data.roles) labels[`role:${r.id}`] = r.name;
for (const p of practicesEntry.data.practices) labels[`practice:${p.id}`] = p.name;
labels['process'] = 'プロセス全体';

const kb = {
  questions: questionsEntry.data.questions,
  rules,
  constraints: constraintsEntry.data.constraints,
  labels,
  gates: integrated.data.gates.map((g) => ({ id: g.id, name: g.name })),
};
---

<StarlightPage
  frontmatter={{
    title: 'プロセス提案シミュレーター(プロトタイプ)',
    description:
      'チームの条件を入力すると、統合プロセス参照モデルをテーラリングした提案を根拠つきで表示する',
    tableOfContents: false,
  }}
>
  <p>
    7つの質問に答えると、<a href={`${b}processes/integrated/`}>統合プロセス参照モデル</a
    >をあなたのチーム向けに調整した提案を、根拠つきで表示します。入力内容がブラウザの外へ送信されることはありません(<a
      href={`${b}tool/requirements/`}>要件定義</a
    >)。
  </p>

  <section id="question-form" aria-label="質問">
    {
      kb.questions.map((q, i) => (
        <div class="question" data-qid={q.id}>
          <p class="question-text">
            <strong>
              Q{i + 1}. {q.text}
            </strong>
            {q.help && <span class="help">({q.help})</span>}
          </p>
          <div class="options" role="radiogroup" aria-label={q.text}>
            {q.options.map((o) => (
              <label class="option">
                <input type="radio" name={q.id} value={o.id} />
                <span>{o.label}</span>
                {o.note && <small>{o.note}</small>}
              </label>
            ))}
          </div>
        </div>
      ))
    }
  </section>

  <div id="result-placeholder">
    <p>すべての質問に答えると、ここに提案が表示されます。</p>
  </div>

  <section id="result" hidden aria-label="提案結果">
    <h2>あなたのチームへの提案</h2>
    <div id="warnings"></div>
    <h3>ゲートの調整</h3>
    <div class="table-wrap"><table id="gates-table"></table></div>
    <h3>ロール・運用の調整</h3>
    <ul id="other-adjustments"></ul>
    <h3>調整の根拠</h3>
    <p>
      すべての調整は知識ベースの規則に由来します。上書きされた調整(取り消し線)も、判断の過程として残しています。
    </p>
    <ul id="trace-list"></ul>
    <h3>チームでの修正と採択</h3>
    <p>
      提案は出発点です。ゲート表の「あなたの修正」列で各ゲートの扱いを上書きできます。提案より弱める方向の修正は<strong>逸脱</strong>として提案書に記録されます。修正を含めた状態はこのページの
      URL に保存されるので、リンクを渡せばチームの他メンバーが同じ内容を確認できます。
    </p>
    <div id="deviations"></div>
    <div class="constraints-box">
      <strong>どの修正でも外せない3つの不変条件</strong>
      <ul>
        {kb.constraints.map((c) => <li>{c.description}(理由: {c.rationale})</li>)}
      </ul>
    </div>
    <p>
      <button id="copy-md" type="button">提案書をコピー(Markdown)</button>
      <button id="download-md" type="button">提案書をダウンロード(.md)</button>
      <span id="copy-status" role="status"></span>
    </p>
    <p>
      ベースの全体像は<a href={`${b}processes/integrated/`}>統合プロセス参照モデル</a
      >、実装方法は<a href={`${b}phase5-implementation/git-strategy/`}>フェーズ5の実装リファレンス</a
      >を参照してください。採択したら、提案書を自組織のリポジトリへ持ち帰って版管理を始めてください。
    </p>
  </section>

  <script type="application/json" id="kb-data" set:html={JSON.stringify(kb)} />

  <script>
    import { evaluate, visibleQuestions } from '../../lib/tailoring-engine.mjs';

    const kb = JSON.parse(document.getElementById('kb-data')!.textContent!);
    const form = document.getElementById('question-form')!;
    const resultEl = document.getElementById('result')!;
    const placeholderEl = document.getElementById('result-placeholder')!;

    const STATE_LABELS: Record<string, string> = {
      standard: '標準どおり',
      omit: '省略',
      simplify: '簡略化',
      strengthen: '厳格化',
    };
    const stateLabel = (state: string) =>
      state.startsWith('merged-into:')
        ? `${kb.labels[`gate:${state.slice('merged-into:'.length)}`] ?? state}へ統合`
        : (STATE_LABELS[state] ?? state);
    const targetLabel = (t: { type: string; id?: string }) =>
      kb.labels[t.id ? `${t.type}:${t.id}` : t.type] ?? (t.id ?? t.type);
    const esc = (s: string) =>
      s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c]!);
    // エンジンの警告文に含まれる内部キー(例: gate:g-ship)と操作名を表示名へ置き換える
    const ACTION_LABELS: Record<string, string> = {
      omit: '省略',
      simplify: '簡略化',
      strengthen: '厳格化',
      'merge-into': '統合',
    };
    const humanize = (s: string) =>
      s
        .replace(/(?:gate|role|practice|phase|activity):[a-z0-9-]+/g, (m) => kb.labels[m] ?? m)
        .replace(/「(omit|simplify|strengthen|merge-into)」/g, (_, a) => `「${ACTION_LABELS[a]}」`);

    function currentAnswers(): Record<string, string> {
      const answers: Record<string, string> = {};
      for (const input of form.querySelectorAll<HTMLInputElement>('input:checked')) {
        answers[input.name] = input.value;
      }
      return answers;
    }

    // ユーザーによるゲート上書き(gateId → 状態)。URL に載せてチーム共有できる
    const overrides: Record<string, string> = {};
    // 統制の強さの序列(逸脱=提案より弱める方向の修正の判定に使う)
    const RANK: Record<string, number> = { omit: 0, simplify: 1, 'merged-into': 1, standard: 2, strengthen: 3 };
    const rankOf = (s: string) => RANK[s.split(':')[0]] ?? 2;

    // 回答と修正を URL ハッシュへ保存・復元する(リンクを渡せば同じ提案+修正が再現される)
    function saveState(answers: Record<string, string>) {
      const state: Record<string, string> = { ...answers };
      for (const [gid, v] of Object.entries(overrides)) state[`ov:${gid}`] = v;
      history.replaceState(null, '', `#${new URLSearchParams(state)}`);
    }
    function restoreHash() {
      for (const [key, val] of new URLSearchParams(location.hash.slice(1))) {
        if (key.startsWith('ov:')) {
          overrides[key.slice(3)] = val;
          continue;
        }
        const input = form.querySelector<HTMLInputElement>(
          `input[name="${CSS.escape(key)}"][value="${CSS.escape(val)}"]`
        );
        if (input) input.checked = true;
      }
    }

    function render() {
      const answers = currentAnswers();
      const visible = visibleQuestions(kb.questions, answers);
      const visibleIds = new Set(visible.map((q: { id: string }) => q.id));

      // 条件付き質問の表示・非表示
      for (const div of form.querySelectorAll<HTMLElement>('.question')) {
        div.hidden = !visibleIds.has(div.dataset.qid!);
      }

      const answered = visible.every((q: { id: string }) => answers[q.id]);
      resultEl.hidden = !answered;
      placeholderEl.hidden = answered;
      if (!answered) return;
      saveState(Object.fromEntries(Object.entries(answers).filter(([q]) => visibleIds.has(q))));

      const result = evaluate(kb, answers);
      lastResult = result;
      const { profile, trace, warnings } = result;

      // 警告(規則同士の衝突)
      document.getElementById('warnings')!.innerHTML = warnings.length
        ? `<div class="warning-box"><strong>⚠ この組み合わせには衝突があります</strong><ul>${warnings
            .map((w: { message: string }) => `<li>${esc(humanize(w.message))}</li>`)
            .join('')}</ul><p>衝突は自動解決済みですが、チームでの判断を推奨します。</p></div>`
        : '';

      // ゲート一覧(参照モデルの全ゲート+調整状態+ユーザー修正)
      const OVERRIDE_CHOICES = ['standard', 'simplify', 'strengthen', 'omit'];
      document.getElementById('gates-table')!.innerHTML =
        `<thead><tr><th>ゲート</th><th>この提案での扱い</th><th>調整内容</th><th>あなたの修正</th></tr></thead><tbody>${kb.gates
          .map((g: { id: string; name: string }) => {
            const p = profile[`gate:${g.id}`];
            const state = p?.state ?? 'standard';
            const details = p
              ? [...Object.entries(p.params).map(([k, v]) => `${k}: ${v}`), ...p.notes]
              : [];
            const options = OVERRIDE_CHOICES.map(
              (v) =>
                `<option value="${v}"${overrides[g.id] === v ? ' selected' : ''}>${STATE_LABELS[v]}</option>`
            ).join('');
            return `<tr><td>${esc(g.name)}</td><td><span class="state state-${state.split(':')[0]}">${esc(
              stateLabel(state)
            )}</span></td><td>${details.map((d) => esc(String(d))).join('<br>') || '—'}</td><td><select data-gate="${
              g.id
            }"><option value="">提案どおり</option>${options}</select></td></tr>`;
          })
          .join('')}</tbody>`;

      // ゲート以外(ロール・プラクティス・プロセス全体)の調整
      const others = Object.values(profile).filter(
        (p: any) => p.target.type !== 'gate'
      ) as Array<{ target: { type: string; id?: string }; notes: string[] }>;
      document.getElementById('other-adjustments')!.innerHTML = others.length
        ? others
            .map(
              (p) =>
                `<li><strong>${esc(targetLabel(p.target))}</strong>: ${p.notes.map(esc).join(' / ')}</li>`
            )
            .join('')
        : '<li>参照モデルからの変更はありません。</li>';

      // 調整の根拠(トレース)
      document.getElementById('trace-list')!.innerHTML = trace
        .map((t: any) => {
          const text = `<strong>${esc(targetLabel(t.target))}</strong>: ${esc(t.note)} <small>(理由: ${esc(
            t.reason
          )} / <a href="${esc(t.source)}">根拠</a>)</small>`;
          return t.status === 'applied' ? `<li>${text}</li>` : `<li class="overridden"><s>${text}</s></li>`;
        })
        .join('');

      renderAdoption();
    }

    let lastResult: any = null;
    const proposalState = (gateId: string) =>
      lastResult?.profile[`gate:${gateId}`]?.state ?? 'standard';
    const effectiveState = (gateId: string) => overrides[gateId] ?? proposalState(gateId);

    // 修正の一覧と逸脱判定(提案より弱める方向の修正は逸脱として明示する)
    function deviationList() {
      return Object.entries(overrides)
        .filter(([gid, v]) => v !== proposalState(gid))
        .map(([gid, v]) => ({
          gateId: gid,
          name: kb.labels[`gate:${gid}`] ?? gid,
          from: stateLabel(proposalState(gid)),
          to: stateLabel(v),
          weakening: rankOf(v) < rankOf(proposalState(gid)),
        }));
    }

    function renderAdoption() {
      const devs = deviationList();
      document.getElementById('deviations')!.innerHTML = devs.length
        ? `<ul>${devs
            .map(
              (d) =>
                `<li>${d.weakening ? '⚠ ' : ''}<strong>${esc(d.name)}</strong>: 提案「${esc(d.from)}」→ 修正「${esc(
                  d.to
                )}」${d.weakening ? ' <small>(統制を弱める修正のため、逸脱として提案書に記録されます)</small>' : ''}</li>`
            )
            .join('')}</ul>`
        : '<p>修正はありません(提案どおり)。</p>';
    }

    // 提案書(Markdown)の生成 — 提案書テンプレートの簡易版に流し込む
    function buildMarkdown() {
      const answers = currentAnswers();
      const visible = visibleQuestions(kb.questions, answers);
      const devs = deviationList();
      const lines: string[] = [
        '# 開発プロセス導入提案書(ドラフト)',
        '',
        `- 生成: [Process Compass プロセス提案シミュレーター](${location.href.split('#')[0]})`,
        `- 共有URL(入力と修正を再現): ${location.href}`,
        `- ベース: [統合プロセス参照モデル](https://takenori-kusaka.github.io/process-compass/processes/integrated/)`,
        '',
        '## 前提(入力した条件)',
        '',
        ...visible.map((q: any) => {
          const opt = q.options.find((o: any) => o.id === answers[q.id]);
          return `- ${q.text} — **${opt?.label ?? '未回答'}**`;
        }),
        '',
        '## 提案するゲート構成(チーム修正を反映)',
        '',
        '| ゲート | 扱い | 調整内容 |',
        '| --- | --- | --- |',
        ...kb.gates.map((g: any) => {
          const p = lastResult?.profile[`gate:${g.id}`];
          const details = p
            ? [...Object.entries(p.params).map(([k, v]) => `${k}: ${v}`), ...p.notes]
            : [];
          const mark = overrides[g.id] && overrides[g.id] !== proposalState(g.id) ? '(チーム修正)' : '';
          return `| ${g.name} | ${stateLabel(effectiveState(g.id))}${mark} | ${details.join(' / ') || '—'} |`;
        }),
        '',
        '## ロール・運用の調整',
        '',
        ...Object.values(lastResult?.profile ?? {})
          .filter((p: any) => p.target.type !== 'gate')
          .map((p: any) => `- **${targetLabel(p.target)}**: ${p.notes.join(' / ')}`),
        '',
        '## チームによる修正と逸脱',
        '',
        ...(devs.length
          ? devs.map(
              (d) =>
                `- ${d.weakening ? '⚠ **逸脱** ' : ''}${d.name}: 提案「${d.from}」→ 修正「${d.to}」`
            )
          : ['- 修正なし(提案どおり)']),
        '',
        '## 不変条件(どの修正でも維持する)',
        '',
        ...kb.constraints.map((c: any) => `- ${c.description}(理由: ${c.rationale})`),
        '',
        '## 調整の根拠',
        '',
        ...(lastResult?.trace ?? [])
          .filter((t: any) => t.status === 'applied')
          .map(
            (t: any) =>
              `- ${targetLabel(t.target)}: ${t.note}(理由: ${t.reason} / [根拠](https://takenori-kusaka.github.io${t.source}))`
          ),
        '',
        '## 次のステップ',
        '',
        '1. この提案書をチーム・関係部門と協議し、修正を確定する',
        '2. 採択したら自組織のリポジトリで版管理を始める(この文書が v1)',
        '3. 運用の実装は[フェーズ5 実装リファレンス](https://takenori-kusaka.github.io/process-compass/phase5-implementation/git-strategy/)、導入後の運用は[フェーズ6](https://takenori-kusaka.github.io/process-compass/phase6-operation/operations-catalog/)を参照する',
        '',
      ];
      return lines.join('\n');
    }

    document.getElementById('gates-table')!.addEventListener('change', (e) => {
      const sel = (e.target as HTMLElement).closest<HTMLSelectElement>('select[data-gate]');
      if (!sel) return;
      if (sel.value) overrides[sel.dataset.gate!] = sel.value;
      else delete overrides[sel.dataset.gate!];
      saveState(currentAnswers());
      renderAdoption();
      e.stopPropagation();
    });

    const statusEl = document.getElementById('copy-status')!;
    document.getElementById('copy-md')!.addEventListener('click', async () => {
      await navigator.clipboard.writeText(buildMarkdown());
      statusEl.textContent = 'コピーしました';
      setTimeout(() => (statusEl.textContent = ''), 3000);
    });
    document.getElementById('download-md')!.addEventListener('click', () => {
      const url = URL.createObjectURL(new Blob([buildMarkdown()], { type: 'text/markdown' }));
      const a = Object.assign(document.createElement('a'), { href: url, download: 'process-proposal.md' });
      a.click();
      URL.revokeObjectURL(url);
    });

    form.addEventListener('change', () => {
      // 回答が変わると提案が変わるため、古い修正は破棄する
      for (const k of Object.keys(overrides)) delete overrides[k];
      render();
    });
    restoreHash();
    render();
  </script>

  <style>
    .question {
      margin-block: 1rem;
    }
    .question-text {
      margin-bottom: 0.3rem;
    }
    .help {
      font-weight: normal;
      font-size: var(--sl-text-sm);
      color: var(--sl-color-gray-2);
    }
    .options {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .option {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 0.5rem;
      padding: 0.4rem 0.8rem;
      cursor: pointer;
    }
    .option:has(input:checked) {
      border-color: var(--sl-color-accent);
      background: var(--sl-color-accent-low);
    }
    .option small {
      color: var(--sl-color-gray-2);
    }
    .warning-box {
      border: 1px solid var(--sl-color-orange);
      border-radius: 0.5rem;
      padding: 0.8rem 1rem;
      margin-block: 1rem;
    }
    .warning-box ul {
      margin-block: 0.5rem;
    }
    .table-wrap {
      overflow-x: auto;
    }
    .state {
      white-space: nowrap;
      border-radius: 0.4rem;
      padding: 0.1rem 0.5rem;
      font-size: var(--sl-text-sm);
    }
    .state-standard {
      background: var(--sl-color-gray-6);
    }
    .state-omit {
      background: var(--sl-color-gray-5);
      text-decoration: line-through;
    }
    .state-simplify,
    .state-merged-into {
      background: var(--sl-color-blue-low);
      color: var(--sl-color-blue-high);
    }
    .state-strengthen {
      background: var(--sl-color-orange-low);
      color: var(--sl-color-orange-high);
    }
    li.overridden {
      color: var(--sl-color-gray-3);
    }
    .constraints-box {
      border: 1px solid var(--sl-color-gray-5);
      border-left: 4px solid var(--sl-color-accent);
      border-radius: 0.5rem;
      padding: 0.8rem 1rem;
      margin-block: 1rem;
    }
    button {
      border: 1px solid var(--sl-color-gray-4);
      border-radius: 0.5rem;
      padding: 0.4rem 0.9rem;
      background: var(--sl-color-accent-low);
      color: var(--sl-color-white);
      cursor: pointer;
      margin-inline-end: 0.5rem;
    }
    button:hover {
      background: var(--sl-color-accent);
    }
    #copy-status {
      color: var(--sl-color-green);
    }
    select {
      border: 1px solid var(--sl-color-gray-4);
      border-radius: 0.4rem;
      padding: 0.15rem 0.3rem;
      background: var(--sl-color-black);
      color: var(--sl-color-white);
    }
  </style>
</StarlightPage>
